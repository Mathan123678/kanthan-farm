generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bird {
  bird_id       Int      @id @default(autoincrement())
  name          String
  breed         String?
  weight        Float?
  age           Int?
  color         String?
  health_status String?
  match_ready   Boolean? @default(false)
  buy_price     Float?
  buy_date      DateTime? @db.Date
  seller        String?
  location      String?
  status        String?  @default("Growing")
  photo         String?

  sales         Sale[]
  healthRecords HealthRecord[]
  matches       Match[]

  @@map("birds")
}

model Sale {
  sale_id        Int      @id @default(autoincrement())
  bird_id        Int?
  bird           Bird?    @relation(fields: [bird_id], references: [bird_id], onDelete: SetNull)
  buyer_name     String?
  buyer_state    String?
  selling_price  Float?
  selling_date   DateTime? @db.Date
  transport_cost Float?   @default(0)
  other_expenses Float?   @default(0)
  profit         Float?   @default(0)
  notes          String?

  @@map("sales")
}

model Expense {
  expense_id  Int      @id @default(autoincrement())
  date        DateTime @db.Date
  category    String
  amount      Float
  description String?

  @@map("expenses")
}

model HealthRecord {
  health_id        Int       @id @default(autoincrement())
  bird_id          Int?
  bird             Bird?     @relation(fields: [bird_id], references: [bird_id], onDelete: Cascade)
  vaccination_date DateTime? @db.Date
  medicine         String?
  doctor           String?
  notes            String?

  @@map("health_records")
}

model Match {
  match_id   Int       @id @default(autoincrement())
  bird_id    Int?
  bird       Bird?     @relation(fields: [bird_id], references: [bird_id], onDelete: Cascade)
  match_date DateTime? @db.Date
  opponent   String?
  result     String?
  notes      String?

  @@map("matches")
}

model Buyer {
  buyer_id        Int     @id @default(autoincrement())
  name            String
  phone           String?
  state           String?
  total_purchases Float?  @default(0)

  @@map("buyers")
}
