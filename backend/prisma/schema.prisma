generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@localhost:51214/template1?sslmode=disable"
}

model Bird {
  bird_id        Int       @id @default(autoincrement())
  name           String
  breed          String
  weight         Float
  age            Int       // in months
  color          String
  health_status  String    @default("Good")
  match_ready    Boolean   @default(false)
  buy_price      Float
  buy_date       DateTime  @default(now())
  seller         String?
  location       String?
  status         String    @default("Growing") // Growing, Training, ReadyForMatch, Sold
  photo          String?
  created_at     DateTime  @default(now())

  sales          Sale[]
  healthRecords  HealthRecord[]
  matches        Match[]

  @@map("birds")
}

model Sale {
  id              Int      @id @default(autoincrement())
  bird_id         Int      @unique
  bird            Bird     @relation(fields: [bird_id], references: [bird_id])
  buyer_name      String
  buyer_state     String
  selling_price   Float
  selling_date    DateTime @default(now())
  transport_cost  Float    @default(0)
  other_expenses  Float    @default(0)
  profit          Float
  notes           String?
  created_at      DateTime @default(now())

  @@map("sales")
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  category    String   // BirdPurchase, Food, Medicine, Transport, Labour, FarmMaintenance, Other
  amount      Float
  description String?
  created_at  DateTime @default(now())

  @@map("expenses")
}

model HealthRecord {
  id               Int       @id @default(autoincrement())
  bird_id          Int
  bird             Bird      @relation(fields: [bird_id], references: [bird_id])
  vaccination_date DateTime
  medicine         String?
  doctor_name      String?
  notes            String?
  created_at       DateTime  @default(now())

  @@map("health_records")
}

model Match {
  id             Int      @id @default(autoincrement())
  bird_id        Int
  bird           Bird     @relation(fields: [bird_id], references: [bird_id])
  match_date     DateTime
  opponent_type  String?
  result         String   // Win, Loss, Draw
  notes          String?
  created_at     DateTime @default(now())

  @@map("matches")
}

model Buyer {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String?
  state           String?
  total_purchases Float    @default(0)
  created_at      DateTime @default(now())

  @@map("buyers")
}
